// Premier Clean & Seal CRM — database schema
// Milestone 0: full domain model in place; features light up milestone by milestone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenancy & users
// ---------------------------------------------------------------------------

model Organisation {
  id      String @id @default(cuid())
  name    String
  logoUrl String?

  // ----- Business settings (Settings page) -----
  vatRegistered         Boolean @default(false) // Premier C&S: not yet registered
  vatRatePercent        Decimal @default(20) @db.Decimal(5, 2)
  vatNumber             String?
  defaultWarrantyMonths Int     @default(12)
  defaultReminderMonths Int     @default(12)

  // Numbering. Format = literal prefix + run of 0s giving pad width.
  // e.g. "#Q-0000" -> #Q-0001, #Q-0002 ...
  quoteNumberFormat   String @default("#Q-0000")
  invoiceNumberFormat String @default("#I-0000")
  jobNumberFormat     String @default("#J-0000")
  quoteCounter        Int    @default(0)
  invoiceCounter      Int    @default(0)
  jobCounter          Int    @default(0)

  users        User[]
  customers    Customer[]
  enquiries    Enquiry[]
  quotes       Quote[]
  jobs         Job[]
  products     Product[]
  campaigns    Campaign[]
  reminders    MarketingReminder[]
  tags         Tag[]
  auditLogs    AuditLog[]
  permissions  Permission[]
  mediaFiles   MediaFile[]
  insightReports InsightReport[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  ADMIN
  OFFICE
  ESTIMATOR
  TECHNICIAN
  SALES
  READONLY
  // Read-only, finance-scoped: the Finance area + invoice/quote/job
  // financial totals and exports only. See src/lib/permissions.ts and
  // src/app/(crm)/layout.tsx for the server-side route/action enforcement.
  ACCOUNTANT
}

model User {
  id             String  @id @default(cuid())
  clerkId        String? @unique
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  email          String  @unique
  // Legacy single-role column -- kept for backward compatibility, mirrored
  // to the highest-priority entry in roles[] on every write (see
  // primaryRole() in user.service.ts). No application logic reads this
  // field anymore; roles[] is the source of truth. See hasRole()/
  // hasAnyRole() in src/lib/permissions.ts.
  role           Role    @default(OFFICE)
  roles          Role[]  @default([])
  active         Boolean @default(true)
  jobsAssigned   Job[]
  enquiries      Enquiry[]
  createdAt      DateTime @default(now())

  // Route planner "finish at home" end point. Geocoded once on save and
  // cached, same GB-constrained pattern as Property lat/lng, so planRoute
  // can use it as a fixed final destination without re-geocoding on every
  // plan. Either the technician themselves or an admin/office user can set
  // this — see setTechnicianHomeAddressAction.
  homeAddress   String?
  homeLatitude  Float?
  homeLongitude Float?
}

model Permission {
  id             String @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  role           Role
  resource       String
  actions        String[]

  @@unique([organisationId, role, resource])
}

// ---------------------------------------------------------------------------
// Customers & properties
// ---------------------------------------------------------------------------

model Customer {
  id             String  @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  company        String?
  phone          String?
  email          String?
  notes          String?
  marketingEmail Boolean @default(false)
  marketingSms   Boolean @default(false)
  consentAt      DateTime?
  totalSpend     Decimal @default(0) @db.Decimal(12, 2)

  properties     Property[]
  enquiries      Enquiry[]
  quotes         Quote[]
  jobs           Job[]
  invoices       Invoice[]
  timeline       TimelineEvent[]
  communications CommunicationLog[]
  reminders      MarketingReminder[]
  portalTokens   PortalToken[]
  mediaFiles     MediaFile[]
  tags           Tag[]           @relation("CustomerTags")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  anonymisedAt DateTime? // set by the GDPR "erase" action; personal fields are scrubbed at that point

  @@index([organisationId, name])
}

model Tag {
  id             String   @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  colour         String   @default("#3C2263") // hex; shown as a chip
  customers      Customer[] @relation("CustomerTags")
  createdAt      DateTime @default(now())

  @@unique([organisationId, name])
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  HOTEL
  OFFICE
  HOSPITAL
  OTHER
}

model Property {
  id           String  @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  addressLine1 String
  addressLine2 String?
  city         String?
  postcode     String
  propertyType PropertyType @default(RESIDENTIAL)
  notes        String?
  // Cached Mapbox geocode result (Milestone 13 — job map). Set once on first
  // lookup and reused forever unless the address changes, to protect the
  // Mapbox free tier from repeat geocoding on every map load.
  latitude     Float?
  longitude    Float?
  createdAt    DateTime @default(now())
  // Soft delete — mirrors Customer.deletedAt/Job.deletedAt. deletedById is a
  // plain scalar (no relation), same convention as Job.deletedById. Deleting
  // a property never cascades — jobs/enquiries/work-log history referencing
  // it survive untouched, only its own visibility (lists/pickers/maps) is
  // hidden. See src/services/customer.service.ts.
  deletedAt      DateTime?
  deletedById    String?
  jobs         Job[]
  enquiries    Enquiry[]
  workLogEntries PropertyWorkLog[]

  @@index([postcode])
}

// Per-property history of sealant work carried out — independent of the
// (not yet built) Jobs module so repeat-business lookups work today.
// Once Jobs/MaterialUsage are live for scheduled work, this remains the
// durable record of what was actually installed and where.
model PropertyWorkLog {
  id           String            @id @default(cuid())
  propertyId   String
  property     Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  description  String
  productId    String?
  product      Product?          @relation(fields: [productId], references: [id])
  productText  String
  colour       String
  area         ApplicationArea?
  batchNumber  String?
  completedAt  DateTime
  photos       MediaFile[]
  createdAt    DateTime          @default(now())

  @@index([propertyId, completedAt])
}

// ---------------------------------------------------------------------------
// Enquiries & pipeline
// ---------------------------------------------------------------------------

enum WorkType {
  BATHROOM
  KITCHEN
  SHOWER
  EXTERNAL_WINDOWS
  EXPANSION_JOINTS
  FIRE_SEALANT
  CUT_OUT_RESEAL
  NEW_SILICONE
  OTHER
}

enum ContactMethod {
  PHONE
  EMAIL
  SMS
  WHATSAPP
}

enum EnquiryStage {
  NEW
  CONTACTED
  SITE_VISIT_BOOKED
  QUOTED
  WAITING_DECISION
  ACCEPTED
  REJECTED
  BOOKED
  COMPLETED
  FOLLOW_UP
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Enquiry {
  id             String  @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id])

  // Raw submission (kept verbatim even after linking to a customer)
  name             String
  company          String?
  phone            String
  email            String
  addressText      String
  postcode         String
  propertyType     PropertyType
  workTypes        WorkType[]
  description      String
  preferredContact ContactMethod @default(PHONE)
  preferredDate    DateTime?
  consentGiven     Boolean       @default(false)

  stage          EnquiryStage @default(NEW)
  priority       Priority     @default(NORMAL)
  kanbanOrder    Int          @default(0)
  estimatedValue Decimal?     @db.Decimal(12, 2)
  assignedToId   String?
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])

  files      MediaFile[]
  aiAnalysis AIAnalysis?
  quotes     Quote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId, stage, kanbanOrder])
}

model AIAnalysis {
  id                 String  @id @default(cuid())
  enquiryId          String  @unique
  enquiry            Enquiry @relation(fields: [enquiryId], references: [id])
  findings           Json
  jobSummary         String
  estimatedWork      String
  estimatedMetres    Decimal? @db.Decimal(8, 2)
  suggestedProducts  Json
  suggestedColours   String[]
  suggestedLabourHrs Decimal? @db.Decimal(6, 2)
  quoteNotes         String?
  confidence         Int
  model              String
  editedByUser       Boolean  @default(false)
  createdAt          DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Quotes
// ---------------------------------------------------------------------------

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
}

model Quote {
  id             String      @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  quoteNumber    String      @unique
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id])
  enquiryId      String?
  enquiry        Enquiry?    @relation(fields: [enquiryId], references: [id])
  status         QuoteStatus @default(DRAFT)
  scopeOfWorks   String
  subtotal       Decimal     @db.Decimal(12, 2)
  vatApplied     Boolean     @default(false) // snapshot of org VAT status at issue
  vatRatePercent Decimal     @default(0) @db.Decimal(5, 2)
  vatAmount      Decimal     @default(0) @db.Decimal(12, 2)
  total          Decimal     @db.Decimal(12, 2)
  depositAmount  Decimal?    @db.Decimal(12, 2)
  terms          String?
  warrantyMonths Int?
  pdfUrl         String?
  approvalToken  String?     @unique
  approvedAt     DateTime?
  approvedName   String?
  approvedIp     String?
  expiresAt      DateTime?
  lineItems      QuoteLineItem[]
  job            Job?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  // Soft delete — mirrors Customer.deletedAt / Job.deletedAt.
  deletedAt      DateTime?
  deletedById    String?
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unit        String
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)
}

// ---------------------------------------------------------------------------
// Jobs
// ---------------------------------------------------------------------------

enum JobStatus {
  BOOKED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  DEPOSIT_PAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  REFUNDED
}

model Job {
  id             String    @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  jobNumber      String    @unique
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id])
  quoteId        String?   @unique
  quote          Quote?    @relation(fields: [quoteId], references: [id])
  technicianId   String?
  technician     User?     @relation(fields: [technicianId], references: [id])

  status         JobStatus     @default(BOOKED)
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  // Milestone: weather layer on the calendar — marks outdoor/silicone-in-
  // the-weather jobs so a rain forecast can be shown more prominently than
  // for jobs where rain doesn't matter. Nullable/defaults unset rather than
  // false so existing jobs aren't implicitly asserted as indoor.
  isExternal     Boolean?
  // Soft delete — mirrors Customer.deletedAt. deletedById is a plain scalar
  // (no relation), same convention as CommunicationLog.userId, to avoid
  // needing a named back-relation array on User.
  deletedAt      DateTime?
  deletedById    String?
  actualStart    DateTime?
  actualEnd      DateTime?

  price          Decimal       @db.Decimal(12, 2)
  depositPaid    Decimal       @default(0) @db.Decimal(12, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(UNPAID)

  notes              String?
  internalNotes      String?
  completionNotes    String?
  metresInstalled    Decimal? @db.Decimal(8, 2)
  customerSignature  String?
  satisfactionRating Int?
  aiReport           Json?

  materials   MaterialUsage[]
  files       MediaFile[]
  warranty    Warranty?
  invoice     Invoice?
  reminders   MarketingReminder[]
  healthScore JobHealthScore?
  timeline    TimelineEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId, status, scheduledStart])
}

// ---------------------------------------------------------------------------
// Weather (calendar rain warnings) — not org-scoped, purely location/date
// keyed, since the same forecast applies regardless of which org asked for
// it. See src/services/weather.service.ts.
// ---------------------------------------------------------------------------

model WeatherCache {
  id        String   @id @default(cuid())
  // Rounded to 2 decimal places (~1.1km) so job locations a few streets
  // apart share one cache entry/Open-Meteo call instead of each burning
  // their own.
  latitude  Float
  longitude Float
  date      DateTime // day this forecast is for, stored at UTC midnight
  weatherCode                 Int
  temperatureMaxC             Float
  temperatureMinC             Float
  precipitationProbabilityMax Int
  precipitationSumMm          Float
  fetchedAt DateTime @default(now())

  @@unique([latitude, longitude, date])
}

// ---------------------------------------------------------------------------
// Materials
// ---------------------------------------------------------------------------

model Product {
  id             String  @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  manufacturer   String
  name           String
  colour         String
  finish         String?
  attributes     String[] // FIRE_RATED, NEUTRAL_CURE, ACOUSTIC, LMN, SANITARY
  supplier       String?
  unitCost       Decimal? @db.Decimal(10, 2)
  usages         MaterialUsage[]
  workLogEntries PropertyWorkLog[]

  @@index([organisationId, manufacturer, name, colour])
}

enum ApplicationArea {
  INTERNAL
  EXTERNAL
  BATHROOM
  ENSUITE
  KITCHEN
  WINDOW
  EXPANSION_JOINT
}

model MaterialUsage {
  id              String          @id @default(cuid())
  jobId           String
  job             Job             @relation(fields: [jobId], references: [id])
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  batchNumber     String?
  applicationArea ApplicationArea
  quantityUsed    Decimal         @db.Decimal(10, 2)
  unit            String          @default("tubes")
  cost            Decimal?        @db.Decimal(10, 2)

  @@index([productId])
}

// ---------------------------------------------------------------------------
// Media & documents
// ---------------------------------------------------------------------------

enum MediaKind {
  PHOTO
  VIDEO
  DOCUMENT
  SIGNATURE
}

enum MediaCategory {
  BEFORE
  DURING
  AFTER
  ANNOTATED
  QUOTE_PDF
  INVOICE_PDF
  CERTIFICATE
  RAMS
  RISK_ASSESSMENT
  METHOD_STATEMENT
  INSURANCE
  RECEIPT
  OTHER
}

model MediaFile {
  id             String  @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  jobId          String?
  job            Job? @relation(fields: [jobId], references: [id])
  enquiryId      String?
  enquiry        Enquiry? @relation(fields: [enquiryId], references: [id])
  kind           MediaKind
  category       MediaCategory?
  url            String
  thumbnailUrl   String?
  mimeType       String
  sizeBytes      Int    @default(0)
  pairedWithId   String? // links BEFORE <-> AFTER for sliders
  sharedToPortal Boolean @default(false) // customer portal only shows photos staff have explicitly shared
  uploadedById   String?
  workLogId      String?
  workLog        PropertyWorkLog? @relation(fields: [workLogId], references: [id])
  createdAt      DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Warranty & invoicing
// ---------------------------------------------------------------------------

model Warranty {
  id             String   @id @default(cuid())
  jobId          String   @unique
  job            Job      @relation(fields: [jobId], references: [id])
  startDate      DateTime
  endDate        DateTime
  coverage       String
  certificateUrl String?
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  jobId          String?       @unique
  job            Job?          @relation(fields: [jobId], references: [id])
  subtotal       Decimal       @db.Decimal(12, 2)
  vatApplied     Boolean       @default(false)
  vatRatePercent Decimal       @default(0) @db.Decimal(5, 2)
  vatAmount      Decimal       @default(0) @db.Decimal(12, 2)
  amount         Decimal       @db.Decimal(12, 2)
  status         PaymentStatus @default(UNPAID)
  dueDate        DateTime
  paidAt         DateTime?
  pdfUrl         String?
  createdAt      DateTime      @default(now())
  // Soft delete ("void") — mirrors Customer.deletedAt / Job.deletedAt.
  // Invoices are financial records that must generally be retained (UK:
  // ~6 years), so this hides rather than erases — see the invoice void
  // action in invoice.service.ts.
  deletedAt      DateTime?
  deletedById    String?
}

// ---------------------------------------------------------------------------
// Marketing
// ---------------------------------------------------------------------------

enum Channel {
  EMAIL
  SMS
  WHATSAPP
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  GOOGLE_BUSINESS_PROFILE
}

enum ReminderStatus {
  SCHEDULED
  SENT
  OPENED
  CLICKED
  REPLIED
  CONVERTED
  FAILED
  CANCELLED
  UNSUBSCRIBED
}

model MarketingReminder {
  id             String         @id @default(cuid())
  organisationId String
  organisation   Organisation   @relation(fields: [organisationId], references: [id])
  customerId     String
  customer       Customer       @relation(fields: [customerId], references: [id])
  jobId          String
  job            Job            @relation(fields: [jobId], references: [id])
  dueDate        DateTime
  intervalMonths Int
  channels       Channel[]
  status         ReminderStatus @default(SCHEDULED)
  sentAt         DateTime?
  messageId      String?
  createdAt      DateTime       @default(now())

  @@index([dueDate, status])
}

model Campaign {
  id             String   @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  name           String
  channel        Channel
  content        String
  tone           String?
  aiGenerated    Boolean  @default(false)
  stats          Json?
  createdAt      DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Timeline, comms, audit, health, portal, AI queue
// ---------------------------------------------------------------------------

model TimelineEvent {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  jobId      String?
  job        Job?     @relation(fields: [jobId], references: [id])
  type       String
  title      String
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
}

model CommunicationLog {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  direction  String
  channel    Channel
  subject    String?
  body       String
  userId     String?
  createdAt  DateTime @default(now())
}

model JobHealthScore {
  id         String   @id @default(cuid())
  jobId      String   @unique
  job        Job      @relation(fields: [jobId], references: [id])
  score      Int
  band       String // GREEN | YELLOW | RED
  factors    Json
  computedAt DateTime @default(now())
}

// Milestone 9 — weekly AI business insight reports. periodStart/periodEnd
// are explicit columns (not folded into `data`) so history can be queried
// without touching the Json blob; `data` holds the rest of the digest that
// fed the narrative in `summary`.
model InsightReport {
  id             String   @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  periodStart    DateTime
  periodEnd      DateTime
  summary        String
  data           Json
  createdAt      DateTime @default(now())

  @@index([organisationId, createdAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  userId         String?
  action         String
  resource       String
  resourceId     String?
  before         Json?
  after          Json?
  ip             String?
  createdAt      DateTime @default(now())
}

model PortalToken {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  token      String   @unique
  scope      String[]
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model PendingAITask {
  id        String   @id @default(cuid())
  type      String
  refId     String
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
}
