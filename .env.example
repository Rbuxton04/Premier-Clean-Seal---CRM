# --- Database (Render PostgreSQL or local) ---
DATABASE_URL="postgresql://user:password@localhost:5432/premier_crm"

# --- Clerk (staff authentication) — leave blank to run in open dev mode ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# Milestone 12: Clerk dashboard -> Webhooks -> add endpoint at
# <APP_URL>/api/webhooks/clerk, subscribe to user.created/updated/deleted,
# then paste its signing secret here. Leave blank locally — the webhook route
# skips signature verification gracefully (and still processes events) when
# this isn't set, same pattern as RESEND_WEBHOOK_SECRET below.
CLERK_WEBHOOK_SECRET=

# --- Mapbox (Milestone 13 — job map + route planner) ---
# Dashboard: https://account.mapbox.com/access-tokens/
# NEXT_PUBLIC_MAPBOX_TOKEN can be the default public token (starts pk.) —
# it's exposed to the browser for map rendering only (no billing risk beyond
# map loads, which have a generous free tier).
# MAPBOX_SECRET_TOKEN should be a secret token (starts sk.) with the
# Geocoding and Optimization scopes enabled — used server-side only, never
# sent to the browser. Leave both blank to run with a "no Mapbox token"
# fallback: the map/route UI shows today's jobs as a plain list instead.
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_SECRET_TOKEN=
# Custom Mapbox style for the map view — leave blank to fall back to a
# stock Mapbox style. This is a NEXT_PUBLIC_ var, so it's baked in at BUILD
# time: changing it in Render requires a redeploy (not just a save) to
# take effect. Can be swapped for a different style URL at any time.
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/premiercleanandseal/cmravlt1m002401qzfp597c99

# --- Cloudflare R2 (Milestone 2+; Milestone 12 adds daily backups) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=premier-crm
# Optional — public base URL if the bucket is served through a custom domain
# or public bucket policy. Without it, generated links point at the R2 API
# host directly (fine for private/internal use like backups).
R2_PUBLIC_URL_BASE=

# --- Messaging (Milestone 8) ---
RESEND_API_KEY=
# Optional — enables webhook signature verification for opens/clicks/bounces.
# Leave blank during local dev; the resend webhook route skips verification
# gracefully (and still processes events) when this isn't set.
RESEND_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- AI (Milestone 3) ---
# Provider-agnostic enquiry-photo analysis. AI_MODEL must match AI_PROVIDER:
#   openai    -> AI_MODEL=gpt-4o (or another vision-capable OpenAI model)
#   anthropic -> AI_MODEL=claude-opus-4-8 (or another Claude vision model)
# Leave AI_API_KEY blank to leave the feature disabled (the panel shows a
# "not configured" state rather than erroring).
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o

# --- Ops ---
# Shared by the marketing/insights/backup Render Cron Jobs to authenticate
# against /api/cron/*. Change this from the placeholder before going live —
# the go-live readiness page (/settings/security) flags it red otherwise.
CRON_SECRET=change-me
APP_URL=http://localhost:3000
